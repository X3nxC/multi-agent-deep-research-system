OPENAI_API_KEY=change-me
OPENAI_BASE_URL=https://api.openai.com/v1
# DEEPSEEK_API_KEY=change-me
# DEEPSEEK_BASE_URL=https://api.deepseek.com
COORDINATOR_MODEL=gpt-5.4-nano
WORKER_MODEL=gpt-5.4

# Optional but recommended. If omitted, the app still runs and uses arXiv plus explicit gap notes, but using arxiv only may lead to http 429 Too Many Requests error.
TAVILY_API_KEY=

APP_HOST=127.0.0.1
APP_PORT=8000

PUBLIC_BASE_URL=http://127.0.0.1:8000

SESSION_LOG_FILE=data/session_log.jsonl
COMPLETED_REPORTS_DIR=data/reports

REPORT_LANGUAGE=en-US
MAX_PLAN_TASKS=4
MAX_TAVILY_RESULTS=5
MAX_ARXIV_RESULTS=3
MAX_SNIPPET_CHARS=1200
MAX_REVIEW_LOOPS=2

LOG_LEVEL=INFO
ERROR_LOG_FILE=data/backend-errors.log
